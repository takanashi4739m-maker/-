# 環境変数のサンプル。ローカル開発では本ファイルを .env にコピーして値を設定する。
# .env は .gitignore 済み（コミットしない）。本番は Render の環境変数で設定する。

# 秘密鍵。本番は必ず固有のランダム値を設定する（Render では generateValue で自動生成）。
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret

# デバッグモード。ローカル開発は True、本番は False。
DJANGO_DEBUG=True

# 許可ホスト（カンマ区切り）。本番は Render のホスト名を含める。
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF で信頼する Origin（カンマ区切り、スキーム付き）。本番例:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://festival-yatai.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# データベース接続URL。未設定なら開発用 SQLite にフォールバックする。
# 本番（PostgreSQL）例:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# show_urls コマンドでフルURLを表示するためのベースURL（任意）。例:
# BASE_URL=https://festival-yatai.onrender.com
BASE_URL=
